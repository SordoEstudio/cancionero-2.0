# Supabase — obtené estos valores en https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en servidor — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL base de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Modo demo (solo desarrollo local) ─────────────────────────────────────
# Evita login en middleware y usa service role en APIs de listado/guardado.
# En producción se ignora salvo AUTH_DEMO_ALLOW_PRODUCTION=true (no recomendado).
AUTH_DEMO_MODE=true
# AUTH_DEMO_ALLOW_PRODUCTION=true
# Banner opcional en login / inicio (solo informativo)
NEXT_PUBLIC_AUTH_DEMO_MODE=true
# Tras ejecutar: pnpm demo:create-user — pega el UUID aquí para persistir versiones e imports “tuyos”
# DEMO_USER_ID=
# DEMO_USER_EMAIL=demo@cancionero.local
# DEMO_USER_PASSWORD=DemoCancionero123!
